name: YouTube+Music
description: 精简客户端首页UI屏蔽推荐广告贴片广告以及音乐客户端

compat_arguments:
  上传按钮: 'true'
  短片按钮: 'true'
  选段按钮: 'true'

map_locals:
- match: ^https:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad
  status_code: 200
  body: ''
  binary: true

scriptings:
- http_response:
    name: 广告处理
    match: ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$
    script_url: https://github.com/C-honk/Egern/raw/refs/heads/main/Js/YoutubeEnhance.js
    arguments:
      _compat.$argument: '{"blockUpload":{{{上传按钮}}},"blockImmersive":{{{选段按钮}}},"blockShorts":{{{短片按钮}}}}'
    body_required: true
    binary_body: true

mitm:
  hostnames:
    includes:
    - '*.googlevideo.com'
    - youtubei.googleapis.com
