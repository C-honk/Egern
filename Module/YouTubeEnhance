name: YouTube视频
description: 更新于2026年3月3日

compat_arguments_desc: |
  默认开启关闭快捷入口 使用 true/false 参数控制
compat_arguments:
  关闭上传按钮: 'true'
  关闭短片按钮: 'true'

map_locals:
- match: ^https:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad
  status_code: 200
  body: ' '
  binary: true

scriptings:
- http_response:
    name: 广告处理
    match: ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$
    script_url: https://github.com/C-honk/Egern/raw/refs/heads/main/Js/YoutubeEnhance.js
    arguments:
      _compat.$argument: '{"blockUpload":{{{关闭上传按钮}}},"blockShorts":{{{关闭短片按钮}}}}'
    body_required: true
    binary_body: true

mitm:
  hostnames:
    includes:
    - '*.googlevideo.com'
    - youtubei.googleapis.com
