name: Spotify音乐
description: 屏蔽插播广告切换歌曲广告以及其他广告解锁订阅权限

scriptings:
- http_response:
    name: 解锁处理
    match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$
    script_url: https://github.com/C-honk/Egern/raw/refs/heads/main/Js/PremiumUnlock.js
    body_required: true
    binary_body: true
- http_response:
    name: 搜索处理
    match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/browsita\/v1\/browse
    script_url: https://github.com/C-honk/Egern/raw/refs/heads/main/Js/PremiumUnlock.js
    body_required: true
    binary_body: true
- http_response:
    name: 播放处理
    match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/scrollsita\/v1\/scroll
    script_url: https://github.com/C-honk/Egern/raw/refs/heads/main/Js/PremiumUnlock.js
    body_required: true
    binary_body: true

mitm:
  hostnames:
    includes:
    - '*-spclient.spotify.com'
    - spclient.wg.spotify.com
